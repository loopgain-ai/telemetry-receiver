{
  "name": "loopgain-telemetry-receiver",
  "version": "0.3.3",
  "description": "Cloudflare Worker that ingests anonymized telemetry from the loopgain library and serves the dashboard.",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create loopgain-telemetry",
    "db:schema:remote": "wrangler d1 execute loopgain-telemetry --file=./schema.sql --remote",
    "db:schema:local": "wrangler d1 execute loopgain-telemetry --file=./schema.sql --local",
    "db:migrate:0002:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0002_eta_calibration.sql --remote",
    "db:migrate:0002:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0002_eta_calibration.sql --local",
    "db:migrate:0003:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0003_schema_v3.sql --remote",
    "db:migrate:0003:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0003_schema_v3.sql --local",
    "db:migrate:0004:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0004_alerts.sql --remote",
    "db:migrate:0004:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0004_alerts.sql --local",
    "db:migrate:0005:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0005_actual_dollars_saved.sql --remote",
    "db:migrate:0005:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0005_actual_dollars_saved.sql --local",
    "db:migrate:0006:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0006_actual_dollars_spent.sql --remote",
    "db:migrate:0006:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0006_actual_dollars_spent.sql --local",
    "db:migrate:0007:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0007_funnel.sql --remote",
    "db:migrate:0007:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0007_funnel.sql --local",
    "db:migrate:0009:remote": "wrangler d1 execute loopgain-telemetry --file=./migrations/0009_tier.sql --remote",
    "db:migrate:0009:local": "wrangler d1 execute loopgain-telemetry --file=./migrations/0009_tier.sql --local",
    "issue-token": "node scripts/issue-token.mjs",
    "rotate-token": "node scripts/rotate-token.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.90.1"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopgain-ai/telemetry-receiver"
  }
}
